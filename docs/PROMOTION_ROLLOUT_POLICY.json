{
  "schema": "enc2sop-promotion-policy/v1",
  "required_branches": [
    {
      "name": "main",
      "required_status_checks": [
        "Signed Approval Promotion Gate"
      ]
    },
    {
      "name": "release/**",
      "required_status_checks": [
        "Signed Approval Promotion Gate"
      ]
    }
  ],
  "required_environments": [
    {
      "name": "production-promotion",
      "min_required_reviewers": 1
    }
  ],
  "required_secrets": [
    "SOENC_RELEASE_APPROVAL_KEY_B64"
  ],
  "workflow": {
    "relative_path": ".github/workflows/release_promotion.yml",
    "required_fragments": [
      "name: release-promotion-gate",
      "environment:",
      "name: production-promotion",
      "python ./soenc.py approve-release",
      "python ./soenc.py release",
      "--require-release-approval",
      "python ./soenc.py promotion-dry-run",
      "python ./soenc.py verify-promotion-artifacts",
      "--release-approval-key-b64",
      "--release-approval-key-id",
      "--require-release-approval-signature",
      "--require-ci-context-match",
      "GITHUB_TOKEN",
      "SKIP_PROMOTION_COLLECT",
      "SOENC_RELEASE_APPROVAL_PREVIOUS_KEY_B64",
      "rotation_rehearsal",
      "promotion_evidence_file",
      "promotion_report_file",
      "\"workflow_run_id\": \"${GITHUB_RUN_ID}\"",
      "\"workflow_run_attempt\": \"${GITHUB_RUN_ATTEMPT}\"",
      "\"workflow_ref\": \"${GITHUB_REF}\"",
      "\"workflow_sha\": \"${GITHUB_SHA}\"",
      "\"workflow_name\": \"${GITHUB_WORKFLOW}\"",
      "\"workflow_event\": \"${GITHUB_EVENT_NAME}\"",
      "promotion_policy_file",
      "promotion_workflow_file",
      "GITHUB_RUN_ATTEMPT",
      "promotion_artifact_audit_report_file",
      "rotation_report_file",
      "promotion_run_receipt_file",
      "PROMOTION_POLICY_FILE",
      "PROMOTION_WORKFLOW_FILE",
      "PROMOTION_ARTIFACT_AUDIT_REPORT_FILE",
      "PROMOTION_RUN_RECEIPT_FILE",
      "ROTATION_REPORT_FILE",
      "promotion_artifact_audit_report.json",
      "promotion_run_receipt.json",
      "enc2sop-rotation-rehearsal/v1",
      "if: ${{ always() }}",
      "SOENC_RELEASE_APPROVAL_KEY_B64",
      "if-no-files-found: error"
    ]
  }
}
