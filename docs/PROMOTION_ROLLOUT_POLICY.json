{
  "schema": "enc2sop-promotion-policy/v1",
  "required_branches": [
    {
      "name": "main",
      "required_status_checks": [
        "Signed Approval Promotion Gate"
      ]
    },
    {
      "name": "release/**",
      "required_status_checks": [
        "Signed Approval Promotion Gate"
      ]
    }
  ],
  "required_environments": [
    {
      "name": "production-promotion",
      "min_required_reviewers": 1
    }
  ],
  "required_secrets": [
    "SOENC_RELEASE_APPROVAL_KEY_B64"
  ],
  "workflow": {
    "relative_path": ".github/workflows/release_promotion.yml",
    "required_fragments": [
      "name: release-promotion-gate",
      "environment:",
      "name: production-promotion",
      "python ./soenc.py approve-release",
      "GITHUB_REPOSITORY",
      "GITHUB_REF",
      "GITHUB_SHA",
      "GITHUB_RUN_ID",
      "python ./soenc.py release",
      "--require-release-approval",
      "python ./soenc.py promotion-dry-run",
      "python ./soenc.py verify-promotion-artifacts",
      "--release-approval-key-b64",
      "--release-approval-key-id",
      "--require-release-approval-signature",
      "--require-ci-context-match",
      "--require-artifact-context-consistency",
      "GITHUB_TOKEN",
      "SKIP_PROMOTION_COLLECT",
      "SOENC_RELEASE_APPROVAL_PREVIOUS_KEY_B64",
      "rotation_rehearsal",
      "promotion_evidence_file",
      "promotion_report_file",
      "\"workflow_run_id\": \"${GITHUB_RUN_ID}\"",
      "\"workflow_repository\": \"${GITHUB_REPOSITORY}\"",
      "\"workflow_run_attempt\": \"${GITHUB_RUN_ATTEMPT}\"",
      "\"workflow_run_number\": \"${GITHUB_RUN_NUMBER}\"",
      "\"workflow_retention_days\": \"${GITHUB_RETENTION_DAYS}\"",
      "\"workflow_github_actions\": \"${GITHUB_ACTIONS}\"",
      "\"workflow_ci\": \"${CI}\"",
      "\"workflow_runner_environment\": \"${RUNNER_ENVIRONMENT}\"",
      "\"workflow_runner_os\": \"${RUNNER_OS}\"",
      "\"workflow_runner_arch\": \"${RUNNER_ARCH}\"",
      "\"workflow_runner_name\": \"${RUNNER_NAME}\"",
      "\"workflow_ref\": \"${GITHUB_REF}\"",
      "\"workflow_ref_name\": \"${GITHUB_REF_NAME}\"",
      "\"workflow_ref_type\": \"${GITHUB_REF_TYPE}\"",
      "\"workflow_sha\": \"${GITHUB_SHA}\"",
      "\"workflow_name\": \"${GITHUB_WORKFLOW}\"",
      "\"workflow_name_ref\": \"${GITHUB_WORKFLOW_REF}\"",
      "\"workflow_name_sha\": \"${GITHUB_WORKFLOW_SHA}\"",
      "\"workflow_event\": \"${GITHUB_EVENT_NAME}\"",
      "\"workflow_server_url\": \"${GITHUB_SERVER_URL}\"",
      "\"workflow_api_url\": \"${GITHUB_API_URL}\"",
      "\"workflow_graphql_url\": \"${GITHUB_GRAPHQL_URL}\"",
      "\"workflow_job\": \"${GITHUB_JOB}\"",
      "\"workflow_actor\": \"${GITHUB_ACTOR}\"",
      "\"workflow_triggering_actor\": \"${GITHUB_TRIGGERING_ACTOR}\"",
      "\"workflow_actor_id\": \"${GITHUB_ACTOR_ID}\"",
      "\"workflow_repository_id\": \"${GITHUB_REPOSITORY_ID}\"",
      "\"workflow_repository_owner\": \"${GITHUB_REPOSITORY_OWNER}\"",
      "\"workflow_repository_owner_id\": \"${GITHUB_REPOSITORY_OWNER_ID}\"",
      "\"workflow_ref_protected\": \"${GITHUB_REF_PROTECTED}\"",
      "promotion_policy_file",
      "promotion_workflow_file",
      "GITHUB_RUN_ATTEMPT",
      "GITHUB_RUN_NUMBER",
      "GITHUB_RETENTION_DAYS",
      "GITHUB_ACTIONS",
      "CI",
      "RUNNER_ENVIRONMENT",
      "RUNNER_OS",
      "RUNNER_ARCH",
      "RUNNER_NAME",
      "GITHUB_REF_NAME",
      "GITHUB_REF_TYPE",
      "GITHUB_REF_PROTECTED",
      "GITHUB_WORKFLOW_REF",
      "GITHUB_WORKFLOW_SHA",
      "GITHUB_SERVER_URL",
      "GITHUB_API_URL",
      "GITHUB_GRAPHQL_URL",
      "promotion_artifact_audit_report_file",
      "rotation_report_file",
      "promotion_run_receipt_file",
      "promotion_artifact_bundle_file",
      "GITHUB_JOB",
      "GITHUB_ACTOR",
      "GITHUB_TRIGGERING_ACTOR",
      "GITHUB_ACTOR_ID",
      "GITHUB_REPOSITORY_ID",
      "GITHUB_REPOSITORY_OWNER",
      "GITHUB_REPOSITORY_OWNER_ID",
      "PROMOTION_POLICY_FILE",
      "PROMOTION_WORKFLOW_FILE",
      "PROMOTION_ARTIFACT_AUDIT_REPORT_FILE",
      "PROMOTION_RUN_RECEIPT_FILE",
      "PROMOTION_ARTIFACT_BUNDLE_FILE",
      "ROTATION_REPORT_FILE",
      "promotion_artifact_audit_report.json",
      "promotion_run_receipt.json",
      "promotion_artifact_bundle.zip",
      "enc2sop-rotation-rehearsal/v1",
      "if: ${{ always() }}",
      "SOENC_RELEASE_APPROVAL_KEY_B64",
      "if-no-files-found: error",
      "python ./soenc.py bundle-promotion-artifacts"
    ]
  }
}
